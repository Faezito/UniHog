@{
    ViewData["Title"] = "Relatórios";
}

<div class="container-fluid">
    <div class="">
        @await Component.InvokeAsync("TopoMenus", new { menu = "Relatórios", rota = @Url.Action("Index", "Menu") })
    </div>

    <hr class="mb-4" />

    @if (this.User.GetSenhaTemp())
    {
        @await Html.PartialAsync("_alertaTrocarSenha")
    }
    <div class="row justify-content-center">

        <!-- GESTÃO DE USUARIOS -->
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="alert alert-light alert-menu shadow py-3">
                <h5 class="text-secondary ps-2"><i class="fa-solid fa-user"></i>&nbsp;&nbsp;Usuários</h5>
                <hr />
                <ol>
                    <li><a asp-action="Cadastro" asp-controller="Usuario">Novo Usuário</a></li>
                    <li><a asp-action="Usuarios" asp-controller="Admin">Listar Usuários</a></li>
                    <li><a asp-action="Lista" asp-controller="Tipo" asp-route-rotaId="1">Categorias de Usuário</a></li>
                    <li><a asp-action="Lista" asp-controller="Tipo" asp-route-rotaId="2">Tipos de Endereço</a></li>
                </ol>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="alert alert-light alert-menu shadow py-3">
                <h5 class="text-secondary ps-4">Serviços Externos</h5>
                <hr />
                <ol>
                    <li><a asp-action="ListarEmails" asp-controller="ServicosExternos">E-mails do Sistema</a></li>
                    <li><a asp-action="CadastroEmail" asp-controller="ServicosExternos">Novo E-mail do Sistema</a></li>
                    @if (this.User.GetUserTipoId() < 0)
                    {
                        <li><a asp-action="ListarAPIs" asp-controller="ServicosExternos">APIs</a></li>
                        <li><a asp-action="CadastroAPI" asp-controller="ServicosExternos">Nova API</a></li>
                    }
                </ol>
            </div>
        </div>
    </div>
</div>
