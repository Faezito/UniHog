@model List<TiposModel>

@{
    int rotaId = ViewBag.Rota;
    string titulo = rotaId switch
    {
        1 => "Lista de Categorias de Pessoas",
        2 => "Lista de Tipos de Endereços",
        3 => "Lista de Situações de Pessoas",
        _ => ""
    };

    ViewData["Title"] = titulo;
}
<style>
    a {
        text-decoration: none;
        color: inherit;
    }
</style>

<div class="row justify-content-end">
    <div class="col text-start">
        <h5 class="text-uppercase">@titulo</h5>
    </div>
    <div class="col-auto text-end">
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalTipo">
            <i class="fa-solid fa-key"></i>&nbsp; ADICIONAR
        </button>
        <a asp-controller="Menu" asp-action="Cadastros" class="btn btn-secondary btn-sm">
            <i class="fa-solid fa-reply"></i>&nbsp;
            Voltar
        </a>
    </div>
</div>

<hr class="my-3" />


<div class="col col-md-6 mx-auto">
    <table class="table table-striped table-bordered border-light-subtle mb-0">
        <thead>
            <tr>
                <td class="text-center">ID</td>
                <td class="text-center">Tipo</td>
                @if (rotaId == 1)
                {
                    <td></td>
                }
                @if (rotaId == 3)
                {
                    <td class="text-center">Cor</td>
                }
            </tr>
        </thead>

        @foreach (var tipo in Model)
        {
            <tr>
                <td class="p-1 text-start align-middle">@tipo.ID</td>
                <td class="p-1 text-start align-middle justify-content-between">
                    @tipo.Descricao
                </td>
                <td>
                    @if (rotaId == 1)
                    {
                        <form id="form-deletar" class="col-1">
                            <input type="hidden" name="Selecao" value="@rotaId" />
                            <input type="hidden" name="ID" value="@tipo.ID" />

                            <button type="submit" class="btn btn-danger btn-sm btn-deletar">
                                <i class="fas fa-trash-can"></i>
                            </button>
                        </form>
                    }
                </td>
                @if (rotaId == 3)
                {
                    <td class="text-center @tipo.Cor">
                        <a asp-action="Editar" asp-controller="Tipo" asp-route-id="@tipo.ID">
                            <i class="fa-solid fa-palette"></i>
                        </a>
                    </td>
                }
            </tr>
        }
    </table>
</div>

<!-- Modal Add Cadastro -->
<div class="modal fade" id="modalTipo" tabindex="-1" aria-labelledby="modalTipoLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">
                    Cadastro
                </h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" id="form-cadastro">
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col">
                            <label for="ID">ID</label>
                            @if (rotaId == 1)
                            {
                                <input type="text" class="form-control" id="ID" name="ID" placeholder=" " required>
                            }
                            else
                            {
                                <input type="text" class="form-control" id="ID" readonly placeholder=" ">
                            }

                            <input type="hidden" class="form-control" name="Selecao" value="@rotaId" placeholder=" ">
                        </div>
                        <div class="col">
                            <label for="Tipo">Tipo</label>
                            <input type="text" class="form-control" id="Tipo" name="Descricao" placeholder=" " required>

                            @if (rotaId == 3)
                            {
                                <label name="Cor" class="form-label"> Cor</label>
                                <select name="Cor" class="form-select form-select-sm">
                                    <option class="text-vinhoclaro" value="text-vinhoclaro">Vinho Claro</option>
                                    <option class="text-vinhoescuro" value="text-vinhoescuro">Vinho Escuro</option>
                                    <option class="text-ouro" value="text-ouro">Ouro</option>
                                    <option class="text-ouroescuro" value="text-ouroescuro">Ouro Escuro</option>
                                    <option class="text-orange" value="text-orange">Laranja</option>
                                    <option class="text-darkblue" value="text-darkblue">Azul Escuro</option>
                                    <option class="text-primary" value="text-primary">Azul</option>
                                    <option class="text-secondary" value="text-secondary">Cinza</option>
                                    <option class="text-success" value="text-success">Verde</option>
                                    <option class="text-danger" value="text-danger">Vermelho</option>
                                    <option class="text-warning" value="text-warning">Amarelo</option>
                                    <option class="text-info" value="text-info">Azul Claro</option>
                                    <option class="text-dark" value="text-dark">Preto</option>
                                </select>
                            }
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <div class="row mb-3">
                        <div class="col-auto">
                            <button type="button" id="btnSalvar" class="btn btn-success btn-sm">
                                <span id="texto-salvar">
                                    <i class="fa-solid fa-floppy-disk"></i>&nbsp;
                                    Salvar
                                </span>
                                <span id="loading" style="display:none; text-align:center;" class="spinner-border spinner-border-sm" role="status"></span>
                            </button>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal" aria-label="Close">
                                <i class="fa-solid fa-reply"></i>&nbsp;
                                Cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.btn-deletar', function (e) {
            fn_deletar(e, this, '@Url.Action("Deletar", "Tipo")')
        });

        // TODO: TROCAR POR WRAPPER

        $('#btnSalvar').on('click', function () {
            $.ajax({
                url: '/Tipo/Cadastro',
                type: 'POST',
                data: $('#form-cadastro').serialize(),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                beforeSend: function () {
                    $('#btnSalvar').prop('disabled', true);
                },
                complete: function () {
                    $('#btnSalvar').prop('disabled', false);
                }
            })
            .done(function (response) {
                if (response.success) {
                    window.location.reload();
                }
            })
            .fail(function (xhr) {
                if (xhr.responseJSON) {
                    Swal.fire({
                        icon: 'error',
                        title: xhr.responseJSON.title ?? 'Erro',
                        html: xhr.responseJSON.detail
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Erro',
                        text: 'Erro inesperado ao processar a requisição.'
                    });
                }
            });
        });

    </script>
}
