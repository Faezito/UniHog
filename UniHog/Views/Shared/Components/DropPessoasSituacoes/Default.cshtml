@model List<TiposModel>

@{
    int? selecao = ViewBag.selecionado;
}

@foreach (var tipo in Model)
{
    if (tipo.ID == selecao)
    {
        <option value="@tipo.ID" class="@tipo.Cor" selected>
            @tipo.Descricao
        </option>
    }
    else
    {
        <option value="@tipo.ID" class="@tipo.Cor">
            @tipo.Descricao
        </option>
    }
}



