@model List<AtendimentoModel>

@{
    var prof = this.User.ObterUsuario();
    List<DiasDaSemana> diasSemana = ViewBag.diasSemana;
    int areaId = ViewBag.areaId;
}
<style>
    .card-menu:hover {
        cursor: pointer;
    }
</style>

<div class="row gap-5 justify-content-center p-4">
    @foreach (var dia in diasSemana)
    {
        int quantidade = Model.Where(x => x.DiaID == dia.DiaID).Count();

        <div class="col-12 col-sm-5 col-md-5 col-lg-3 border shadow-sm rounded card-menu p-3">
            <div id="alert alert-light">
                <h4 class="fs-5 text-secondary ps-3 pb-3 border-bottom justify-content-between d-flex">
                    @dia.Dia  <span class="badge @(quantidade > 0 ? "text-bg-success" : "text-bg-secondary")">@quantidade</span>
                </h4>
                @if (quantidade <= 0)
                {
                    <h6 class="text-center mt-4">SEM AGENDAMENTOS</h6>
                }
                <table class="table table-borderless">
                    @foreach (var item in Model.Where(x => x.DiaID == dia.DiaID).OrderBy(x => x.Paciente).ThenBy(x=>x.Data).ToList())
                    {
                        <tr class="border-bottom-1">
                            <td class="text-start align-middle col-2">@item.DataAtendimento.ToString("HH:mm")</td>
                            <td class="text-start align-middle col-2">@item.Data.ToString("dd/MM")</td>
                            <td class="text-start align-middle col-8">@item.Paciente.NomeCompleto</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    }
</div>
